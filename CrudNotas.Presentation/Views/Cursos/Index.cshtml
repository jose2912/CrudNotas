@model IEnumerable<CrudNotas.EntityLayer.Curso>

<h2>Listado de Cursos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo Curso</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.Nombre</td>
                <td>@curso.Descripcion</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@curso.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@curso.Id" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
