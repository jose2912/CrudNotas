@model CrudNotas.EntityLayer.Curso

<h2>Detalles del Curso</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Descripción</dt>
        <dd class="col-sm-10">@Model.Descripcion</dd>
    </dl>
</div>

<h3>Notas del Curso</h3>

<p>
    <a asp-controller="Notas" asp-action="Create" asp-route-cursoId="@Model.Id" class="btn btn-primary">
        Nueva Nota
    </a>
</p>

@if (Model.Notas != null && Model.Notas.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Título</th>
                <th>Contenido</th>
                <th>Fecha de Creación</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var nota in Model.Notas)
            {
                <tr>
                    <td>@nota.Titulo</td>
                    <td>@nota.Contenido</td>
                    <td>@nota.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-controller="Notas" asp-action="Edit" asp-route-id="@nota.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-controller="Notas" asp-action="Delete" asp-route-id="@nota.Id" class="btn btn-danger btn-sm">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No hay notas registradas para este curso.</p>
}

<p>
    <a asp-action="Index" class="btn btn-secondary">Volver al listado de cursos</a>
</p>
